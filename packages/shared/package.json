{
  "name": "@ticker/shared",
  "version": "0.0.1",
  "private": true,
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint \"src/**/*.ts\""
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "jest": "30.4.2",
    "ts-jest": "29.4.11",
    "typescript": "6.0.3"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.ts"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
