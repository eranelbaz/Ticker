{
  "name": "ticker",
  "private": true,
  "description": "Open-source alternative to TradingView",
  "license": "MIT",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,cjs,json,css}\" --ignore-path .prettierignore"
  },
  "devDependencies": {
    "prettier": "^3.8.4"
  }
}
