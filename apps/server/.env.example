# Alpaca Market Data API credentials (free Basic plan).
# Create keys at https://app.alpaca.markets/ -> Home -> API Keys.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=

# Optional: override the dev server port and the allowed CORS origin.
# PORT=3000
# CORS_ORIGIN=http://localhost:5173

# Dev mode: return an empty history instead of erroring when a symbol has no
# historical bars (e.g. the FAKEPACA test stream). Leave unset in production.
# ALLOW_EMPTY_HISTORY=true

# Market data provider: 'alpaca' (real data) or 'alpaca-fake' (synthetic FAKEPACA stream).
# MARKET_DATA_PROVIDER=alpaca

# Alpaca real-time WebSocket stream URL (default: wss://stream.data.alpaca.markets/v1beta1/stocks/bars).
# Only needed if you want to override the built-in default.
# ALPACA_STREAM_URL=wss://stream.data.alpaca.markets/v1beta1/stocks/bars
