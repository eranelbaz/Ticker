# Alpaca Market Data API credentials (free Basic plan).
# Create keys at https://app.alpaca.markets/ -> Home -> API Keys.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=

# Optional: override the dev server port and the allowed CORS origin.
# PORT=3000
# CORS_ORIGIN=http://localhost:5173

# Dev mode: return an empty history instead of erroring when a symbol has no
# historical bars (e.g. the FAKE test stream). Leave unset in production.
# ALLOW_EMPTY_HISTORY=true

# Market data provider: 'alpaca' (US stocks), 'tradovate' (futures), or 'mock-provider' (synthetic FAKE stream).
# MARKET_DATA_PROVIDER=alpaca

# Alpaca real-time WebSocket stream URL (default: wss://stream.data.alpaca.markets/v1beta1/stocks/bars).
# Only needed if you want to override the built-in default.
# ALPACA_STREAM_URL=wss://stream.data.alpaca.markets/v1beta1/stocks/bars

# Tradovate Market Data credentials. Your account login is always required.
# TRADOVATE_USERNAME=
# TRADOVATE_PASSWORD=
# Optional API key pair (cid/sec) from Tradovate API access. Recommended: without it,
# auth still works but Tradovate throttles credential-only requests (time penalty /
# occasional captcha); the provider waits and retries automatically.
# TRADOVATE_CID=
# TRADOVATE_SECRET=
# Optional: a stable UUID for this device. Reduces captcha challenges; auth works without it.
# TRADOVATE_DEVICE_ID=
# Environment: 'demo' (default) or 'live'. Only switches the REST auth URL.
# TRADOVATE_ENV=demo
# Optional app identity (defaults: Ticker / 1.0).
# TRADOVATE_APP_ID=Ticker
# TRADOVATE_APP_VERSION=1.0
